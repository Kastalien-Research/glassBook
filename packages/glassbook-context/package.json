{
  "name": "@kastalien-research/glassbook-context",
  "version": "0.0.0",
  "description": "Pure recursive context primitives shared by glassBook and Srcbook MCP projection.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "prebuild": "rimraf ./dist",
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "vitest": "^2.0.5"
  }
}
